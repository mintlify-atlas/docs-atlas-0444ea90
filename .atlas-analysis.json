  "keyFeatures": [
    "Low latency WebRTC-based voice communication",
    "Production and line management",
    "WHIP/WHEP protocol support",
    "Symphony Media Bridge integration",
    "MongoDB and CouchDB database support",
    "Docker and Terraform deployment",
    "Rate limiting and security headers",
    "Link sharing and re-authentication"
  ],
  "publicApiSurface": [
    "GET /api/v1/productions - List all productions",
    "POST /api/v1/productions - Create a production",
    "GET /api/v1/productions/:productionId - Get production details",
    "PATCH /api/v1/productions/:productionId - Update production",
    "DELETE /api/v1/productions/:productionId - Delete production",
    "POST /api/v1/productions/:productionId/lines - Create a line",
    "PATCH /api/v1/productions/:productionId/lines/:lineId - Update line",
    "DELETE /api/v1/productions/:productionId/lines/:lineId - Delete line",
    "POST /api/v1/productions/:productionId/lines/:lineId/sessions - Create session",
    "PUT /api/v1/productions/:productionId/lines/:lineId/sessions/:sessionId - Join session",
    "PATCH /api/v1/productions/:productionId/lines/:lineId/sessions/:sessionId - Update session",
    "DELETE /api/v1/productions/:productionId/lines/:lineId/sessions/:sessionId - Leave session",
    "POST /api/v1/whip/:productionId/:lineId - WHIP endpoint for publishing",
    "POST /api/v1/whep/:productionId/:lineId - WHEP endpoint for subscribing",
    "GET /api/v1/ingests - List all ingests",
    "POST /api/v1/ingests - Create ingest",
    "GET /api/v1/ingests/:ingestId - Get ingest details",
    "PATCH /api/v1/ingests/:ingestId - Update ingest",
    "DELETE /api/v1/ingests/:ingestId - Delete ingest"
  ]
